{
  "name": "eglot-typescript-preset",
  "version": "1.0.0",
  "description": "TypeScript LSP preset for Emacs using Eglot",
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "GPL-3.0",
  "scripts": {
    "byte-compile": "./scripts/byte-compile.sh",
    "check": "./scripts/byte-compile.sh --check",
    "check:doc": "./scripts/checkdoc.sh",
    "check:melpa": "./scripts/melpa-check.sh",
    "check:melpa:all": "bun run check:melpa && bun run test:all",
    "check:melpa:install": "./scripts/melpa-build-install-check.sh",
    "check:package-lint": "./scripts/package-lint.sh",
    "init": "bun run up && bun run init:hooks",
    "init:hooks": "lefthook install",
    "fix:md": "prettier --write '**/*.md'",
    "fix:md:file": "prettier --write",
    "fix:yaml": "prettier --write '**/*.yaml'",
    "fix:yaml:file": "prettier --write",
    "hooks:check": "lefthook run pre-commit --all-files --no-stage-fixed",
    "hooks:pre-commit": "lefthook run pre-commit",
    "hooks:pre-commit:all": "lefthook run pre-commit --all-files",
    "test": "emacs -Q --batch -l eglot-typescript-preset.el -l test/test.el -f ert-run-tests-batch-and-exit",
    "test:all": "bun run test && bun run test:live",
    "test:live": "emacs -Q --batch -l eglot-typescript-preset.el -l test/test.el -f my-test-run-live-tests-parallel",
    "test:live:sequential": "emacs -Q --batch -l eglot-typescript-preset.el --eval \"(setq my-test-run-live-tests t)\" -l test/test.el -f ert-run-tests-batch-and-exit",
    "up": "mise use -g bun@latest && mise install && bun install && uv sync"
  },
  "devDependencies": {
    "@astrojs/language-server": "^2.16.2",
    "@biomejs/biome": "^2.3.8",
    "@t1ckbase/vscode-langservers-extracted": "1.0.2",
    "@tailwindcss/language-server": "^0.14.29",
    "@typescript/native-preview": "^7.0.0-dev.20260616.1",
    "@vue/language-server": "^3.2.5",
    "@vue/typescript-plugin": "^3.3.5",
    "eslint": "^9",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-oxlint": "^1.55.0",
    "lefthook": "^2.0.13",
    "oxlint": "^1.32.0",
    "prettier": "^3.7.4",
    "svelte-language-server": "^0.17.23",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "typescript-language-server": "^5.1.3"
  }
}
